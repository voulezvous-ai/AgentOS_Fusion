{
  "$schema": "https://railway.app/railway.schema.json",

  "plugins": {
    "postgres": { "serviceName": "postgres" },
    "redis":    { "serviceName": "redis"   }
  },

  "services": {
    "backend": {
      "sourceDir": "promptos_backend",
      "dockerfilePath": "../docker/backend.Dockerfile",
      "healthcheckPath": "/health",
      "env": { "PORT": "8000" }
    },

    "frontend": {
      "sourceDir": "fusion_app",
      "dockerfilePath": "../docker/frontend.Dockerfile",
      "env": {
        "PORT": "3000",
        "VITE_BACKEND_URL": "https://backend.up.railway.app"
      }
    },

    "worker": {
      "sourceDir": "promptos_backend",
      "dockerfilePath": "../docker/backend.Dockerfile",
      "startCommand": "celery -A promptos_backend.worker worker -l info",
      "env": { "PORT": "8000" }
    }
  }
}
